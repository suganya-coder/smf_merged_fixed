# ── JWT / Auth ───────────────────────────────────────────────
# F-01 FIX: 64-char cryptographic random hex (replaces weak passphrase).
# To regenerate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=3adcb4052de0fb6d77388984b6f60079eb6e44afdf35b9f827fbea6ed072bc61
ALGORITHM=HS256

# F-01 FIX: tightened from 480 → 60 minutes (1-hour session window)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ─────────────────────────────────────────────────
# SQLite (default — no setup needed)
# DATABASE_URL=sqlite:///./attendance.db
# PostgreSQL (uncomment if deploying to prod):
# DATABASE_URL=postgresql://user:pass@localhost/smf_db

# ── Gmail SMTP (sender account — sends ALL emails) ───────────
# This account SENDS the emails (OTPs + attendance alerts).
# Must be a Gmail account with 2FA enabled and an App Password.
# How to get a Gmail App Password:
#   1. Enable 2-Step Verification: https://myaccount.google.com/security
#   2. Go to: https://myaccount.google.com/apppasswords
#   3. Select Mail → your device → Generate
#   4. Paste the 16-character password below
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=errorbug31@gmail.com
# ACTION REQUIRED: rotate SMTP_PASS — current value is compromised
# (was visible in source / version control history).
# Revoke it at: https://myaccount.google.com/apppasswords
# Then generate a new App Password and replace the value below.
SMTP_PASS=paxaytqondowisnl

# ── Role Email Addresses (OTP RECIPIENTS) ────────────────────
# These are the addresses that RECEIVE OTP emails for password reset.
# Admin forgot-password OTP is delivered to:
ADMIN_EMAIL=suganyainbox25@gmail.com
#
# HOD forgot-password OTP (if not stored per-HOD in hods table):
HOD_EMAIL=suganyainbox32@gmail.com
#
# Faculty default email (if faculty has no individual email in DB):
FACULTY_DEFAULT_EMAIL=g3260998@gmail.com

# ── Legacy SMF config (keep for backward compat) ─────────────
ADMIN_USERNAME=admin
# F-01 + F-03 FIX: bcrypt hash stored here (not plain text).
# This hash was generated with: hash_password('YourNewPassword@2025!')
# To change: python -c "from auth_utils import hash_password; print(hash_password('NewPassword@2025!'))"
ADMIN_PASSWORD=$2b$12$GD2UDwUH2FN85mjBMt6KhOQY4r0GI8TEJ.mIut1aAoVrgWgTDb7Du
TEACHER_USERNAME=teacher
TEACHER_PASSWORD=Teacher@2025!
HOD_PASSWORD=Hod@2025!
INCHARGE_PASSWORD=incharge123
FACULTY_DEFAULT_PASSWORD=Faculty@2025!

# F-01 FIX: same 64-char random hex as SECRET_KEY (shared JWT signing key).
# MUST match SECRET_KEY exactly — both sign/verify the same tokens.
API_SECRET_KEY=3adcb4052de0fb6d77388984b6f60079eb6e44afdf35b9f827fbea6ed072bc61
# F-01 FIX: tightened from 8 → 1 hour
API_TOKEN_EXPIRY_HOURS=1
API_PORT=8000
API_HOST=0.0.0.0