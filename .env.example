# ============================================================
#  Smart Attendance System v9.6 — Environment Configuration
#  Copy this to .env and fill in your values:
#      cp .env.example .env
#
#  Bug-5 FIX: This file no longer contains real credentials.
#             All values below are PLACEHOLDERS only.
# ============================================================

# ── JWT / Auth ───────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-secret-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Admin credentials ────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=YourStrongAdminPassword@2025!

# ── Teacher credentials ──────────────────────────────────────
TEACHER_USERNAME=teacher
TEACHER_PASSWORD=YourStrongTeacherPassword@2025!

# ── Role passwords ────────────────────────────────────────────
HOD_PASSWORD=YourHodPassword@2025!
FACULTY_DEFAULT_PASSWORD=YourFacultyPassword@2025!

# ── API settings ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_TOKEN_EXPIRY_HOURS=8
API_SECRET_KEY=changeme_generate_a_real_secret_key_here

# ── Camera ───────────────────────────────────────────────────
CAMERA_INDEX=0

# ── LBPH recognition thresholds ──────────────────────────────
LBPH_THRESHOLD=120
LBPH_UNKNOWN_MARGIN=70
DLIB_DISTANCE=0.50
MIN_CONFIDENCE_PCT=45
CONFIRM_FRAMES_REQUIRED=5

# ── Liveness detection ────────────────────────────────────────
LIVENESS_ON=false
LIVENESS_THRESHOLD=0.28

# ── Notifications ─────────────────────────────────────────────
SMS_ENABLED=false
EMAIL_ENABLED=true

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000,http://localhost:5500

# ── Gmail SMTP (SENDER account — sends ALL emails) ───────────
# This account SENDS emails. Must have 2FA + App Password enabled.
# Steps to get App Password:
#   1. Go to myaccount.google.com
#   2. Security → 2-Step Verification → ON
#   3. Security → App Passwords → Generate
#   4. Paste the 16-digit password below (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_sender_gmail@gmail.com
SMTP_PASS=your_16_digit_app_password_here

# ── Role Email Addresses (OTP RECIPIENTS) ────────────────────
# These are the addresses that RECEIVE OTP emails for password reset.
# Bug-2 FIX: Admin must have a real deliverable email address here.
ADMIN_EMAIL=admin_real_email@gmail.com
HOD_EMAIL=hod_real_email@gmail.com
FACULTY_DEFAULT_EMAIL=faculty_default_email@gmail.com


# Environment secrets — never commit
.env
*.env
!.env.example